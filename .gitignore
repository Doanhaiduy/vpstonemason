# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/extensions.json

# Git / deployment metadata
.vercel/

# Environment secrets (keep templates)
**/.env
**/.env.*
!**/.env.example
!/.env.vps.example

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Node build outputs
backend/node_modules/
backend/dist/
backend/coverage/
backend/.nestjs/

frontend/node_modules/
frontend/.next/
frontend/out/
frontend/tsconfig.tsbuildinfo

# Generated migration/report artifacts
backend/scripts/output/cloudinary/migration-plan-*.json
backend/scripts/output/cloudinary/migration-backup-*.json
backend/scripts/output/cloudinary/range-hero-update-*.json
backend/scripts/output/cloudinary/test-map.json

# Python cache/artifacts (scripts)
**/__pycache__/
*.py[cod]

# Temp crawl outputs
scripts/_tmp_*.json

# Optional local Docker volumes/state
*.pid

# Stone Content Agent — generated images & media (do NOT commit)
docs/image_temp/*.jpg
docs/image_temp/*.jpeg
docs/image_temp/*.png
docs/image_temp/*.webp
docs/content-media/posts/*/raw/
docs/content-media/posts/*/final/
docs/content-media/posts/**/raw/
docs/content-media/posts/**/final/
.github/stone-content/reference-images/*.jpg
.github/stone-content/reference-images/*.jpeg
.github/stone-content/reference-images/*.png
.github/stone-content/reference-images/*.webp
.github/stone-content/output/*/
!.github/stone-content/output/.gitkeep

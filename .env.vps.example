# -------------------------
# Public URLs (required)
# -------------------------
NEXT_PUBLIC_SITE_URL=http://YOUR_SERVER_IP
NEXT_PUBLIC_API_URL=http://YOUR_SERVER_IP/api
INTERNAL_API_URL=http://backend:4000/api
FRONTEND_URL=http://YOUR_SERVER_IP

# -------------------------
# Backend
# -------------------------
PORT=4000
NODE_ENV=production
JWT_SECRET=replace-with-a-long-random-secret
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# -------------------------
# MongoDB (recommended: external MongoDB/Atlas on 2GB VPS)
# -------------------------
DATABASE_URL=mongodb+srv://username:password@your-cluster.mongodb.net/stone-showroom?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://username:password@your-cluster.mongodb.net/stone-showroom?retryWrites=true&w=majority

# If you insist on local MongoDB, use docker-compose.yml (not docker-compose.vps.yml)
# and switch both values to:
# DATABASE_URL=mongodb://mongodb:27017/stone-showroom
# MONGODB_URI=mongodb://mongodb:27017/stone-showroom

# -------------------------
# Optional media service
# -------------------------
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# -------------------------
# Optional AI service (frontend server routes)
# -------------------------
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
